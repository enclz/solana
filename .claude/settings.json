{
  "permissions": {
    "allow": ["Bash(cargo:*)", "Bash(openspec *)"]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.solana/init.sh"
          }
        ]
      }
    ]
  }
}
