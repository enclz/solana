{
  "name": "enclz",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "lint:fix": "prettier */*.ts \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.ts \"*/**/*{.js,.ts}\" --check",
    "test": "ts-mocha -p ./tsconfig.json -t 1000000 tests/**/*.spec.ts",
    "test:e2e": "anchor test --validator legacy",
    "deploy:devnet": "dotenv -- ts-node migrations/deploy.ts --devnet",
    "deploy:mainnet": "dotenv -- ts-node migrations/deploy.ts --mainnet",
    "smoke:devnet": "dotenv -- ts-node tests/smoke.ts",
    "idl:check": "node scripts/check-idl-sync.mjs",
    "idl:sync": "node scripts/sync-idl.mjs"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1"
  },
  "devDependencies": {
    "@solana/spl-token": "^0.4.14",
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "chai": "^4.3.4",
    "dotenv-cli": "^8.0.0",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
